# Instagram Graph API — necessário para o feed automático em
# Portfólio e Feedbacks. Veja o passo a passo no README.md.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Hashtag usada nas legendas para marcar quais posts aparecem na
# seção de Feedbacks (ex: #depoimentoluvia)
INSTAGRAM_TESTIMONIAL_TAG=#depoimentoluvia
